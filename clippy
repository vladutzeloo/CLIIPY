#!/usr/bin/env python3
"""Launcher script for clippy.py - runs it within a managed virtual environment."""
import os
import sys
import platform
import subprocess

# Add the directory of this script to the path to find venv_manager
CLIPPY_DIR = os.path.dirname(os.path.abspath(os.path.realpath(__file__)))
sys.path.insert(0, CLIPPY_DIR)

import venv_manager

def main():
    try:
        venv_python = venv_manager.ensure_venv(CLIPPY_DIR)
    except Exception as e:
        print(f"Error setting up virtual environment: {e}", file=sys.stderr)
        sys.exit(1)

    target_script = os.path.join(CLIPPY_DIR, "clippy.py")
    if not os.path.isfile(target_script):
        print(f"Error: clippy.py not found at '{target_script}'.", file=sys.stderr)
        sys.exit(127)

    args = [venv_python, target_script] + sys.argv[1:]

    try:
        if platform.system() == "Windows":
            result = subprocess.run(args)
            sys.exit(result.returncode)
        else:
            os.execv(venv_python, args)
    except FileNotFoundError as e:
        print(f"Error: Could not find executable: {e}", file=sys.stderr)
        sys.exit(127)
    except subprocess.CalledProcessError as e:
        print(f"Error running clippy: {e}", file=sys.stderr)
        sys.exit(e.returncode)
    except Exception as e:
        print(f"Unexpected error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
